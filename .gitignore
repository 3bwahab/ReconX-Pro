# ===========================================================================
# ReconX-Pro .gitignore
# ===========================================================================

# --- Secrets / Local configuration ----------------------------------------
# NEVER commit your real API keys. Copy config.example.yaml -> config.yaml
config.yaml
.env
.env.*
*.pem
*.key
secrets.*

# --- Scan output / runtime data --------------------------------------------
reports/*
!reports/.gitkeep
logs/*
!logs/.gitkeep

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg
.installed.cfg

# --- Virtual environments --------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# --- Testing / coverage ----------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# --- IDE / Editor ----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS junk ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.lnk
